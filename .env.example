# DeepSeek API (OpenAI-compatible endpoint)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
# 默认模型
DEEPSEEK_MODEL=deepseek-v4-flash

# Fish Audio TTS
FISH_AUDIO_API_KEY=your-fish-audio-key
FISH_AUDIO_API_URL=https://api.fish.audio/v1/tts

# Netease Cloud Music
NETEASE_API_URL=http://localhost:3000
NETEASE_UID=你的网易云用户ID
# 可选：Cookie 直连 (浏览器登录 music.163.com → F12 → Application → Cookies → MUSIC_U)
# NETEASE_COOKIE=MUSIC_U=xxx

# Server
PORT=8080
