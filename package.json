{
  "name": "claudio",
  "version": "1.0.0",
  "private": true,
  "description": "Claudio — Personal AI Radio DJ",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:portable": "node scripts/build-portable.js"
  },
  "build": {
    "appId": "com.star.claudio",
    "productName": "Claudio",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "lib/**/*",
      "lib/sql-wasm.wasm",
      "prompts/**/*",
      "public/**/*",
      "data/**/*",
      "Crt/**/*",
      "node_modules/**/*",
      ".env"
    ],
    "extraResources": [
      { "from": "data", "to": "data" },
      { "from": "Crt", "to": "Crt" }
    ],
    "win": {
      "target": "nsis",
      "icon": "Crt/App icon.png",
      "sign": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Claudio",
      "installerIcon": "Crt/App icon.png",
      "uninstallerIcon": "Crt/App icon.png",
      "artifactName": "${productName}_Setup_${version}.${ext}"
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "@unblockneteasemusic/server": "^0.28.0",
    "@volcengine/openapi": "^1.36.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "edge-tts": "^1.0.1",
    "express": "^4.21.0",
    "morgan": "^1.10.0",
    "NeteaseCloudMusicApi": "^4.31.0",
    "node-cron": "^3.0.3",
    "sql.js": "^1.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
