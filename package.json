{
  "name": "claudio",
  "version": "1.0.0",
  "private": true,
  "description": "Claudio — Personal AI Radio DJ",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "server": "node server.js",
    "build": "node scripts/build-portable.js",
    "build:zip": "node scripts/build-portable.js --zip",
    "proxy": "node node_modules/@unblockneteasemusic/server/precompiled/app.js -p 8081 -e https://music.163.com"
  },
  "build": {
    "appId": "com.claudio.radio",
    "productName": "Claudio",
    "directories": {
      "output": "release"
    },
    "asar": false,
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "cli.js",
      "lib/**/*",
      "lib/sql-wasm.wasm",
      "prompts/**/*",
      "user/**/*",
      "public/**/*",
      "data/**/*",
      "node_modules/**/*",
      "README.md",
      ".env.example"
    ],
    "extraResources": [
      { "from": "data", "to": "data" }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "sign": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "@unblockneteasemusic/server": "^0.28.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "morgan": "^1.10.0",
    "NeteaseCloudMusicApi": "^4.31.0",
    "node-cron": "^3.0.3",
    "sql.js": "^1.12.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
