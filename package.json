{
  "name": "claudio",
  "version": "1.0.0",
  "private": true,
  "description": "Claudio — Personal AI Radio DJ",
  "main": "electron-main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "server": "node server.js",
    "build": "node scripts/build-portable.js",
    "build:zip": "node scripts/build-portable.js --zip"
  },
  "build": {
    "appId": "com.claudio.radio",
    "productName": "Claudio",
    "directories": { "output": "release" },
    "asar": false,
    "files": [
      "electron-main.js",
      "electron-preload.js",
      "server.js",
      "cli.js",
      "lib/**/*",
      "lib/sql-wasm.wasm",
      "prompts/**/*",
      "user/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.png",
      "sign": false,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "forceCodeSigning": false
  },
  "dependencies": {
    "express": "^4.21.0",
    "ws": "^8.18.0",
    "sql.js": "^1.12.0",
    "node-cron": "^3.0.3",
    "dotenv": "^16.4.5",
    "morgan": "^1.10.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
